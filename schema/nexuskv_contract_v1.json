      "DEVICE_TO_HOST",
      "HOST_TO_STORE",
      "STORE_TO_HOST",
      "ASYNC",
      "ZERO_COPY_CANDIDATE"
    ],
    "TierKind": ["DEVICE", "HOST_DRAM", "LOCAL_SSD", "REMOTE_SHARED", "OBJECT_STORE"],
    "MaterializationCapability": ["FULL", "PARTIAL", "PREFETCH", "ASYNC_FETCH", "FALLBACK_RECOMPUTE"],
    "MatchClassification": ["EXACT", "PREFIX", "PARTIAL"],
    "PlanDisposition": ["FULL_REUSE", "PARTIAL_REUSE", "RECOMPUTE"]
