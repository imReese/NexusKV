        {"name": "location", "type": "EntryLocation"},
        {"name": "policy_hint", "type": "PolicyHint"}
      ]
    },
    "MatchExtent": {
      "fields": [
        {"name": "units", "type": "int"},
        {"name": "granularity", "type": "Granularity"}
      ]
    },
    "RemainingWork": {
      "fields": [
        {"name": "tokens", "type": "list[int]"},
        {"name": "fetch_required", "type": "bool"},
        {"name": "recompute_required", "type": "bool"}
