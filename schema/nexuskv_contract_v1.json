        {"name": "identity", "type": "KeyIdentity"}
      ]
    },
    "QueryKey": {
      "fields": [
        {"name": "identity", "type": "KeyIdentity"}
      ]
    },
    "EntryVersion": {
      "fields": [
        {"name": "generation", "type": "int"},
        {"name": "lineage", "type": "string"}
      ]
    },
