        {"name": "layout", "type": "LayoutMetadata"},
        {"name": "compatibility_flags", "type": "list[CompatibilityFlag]"},
        {"name": "transfer_paths", "type": "list[TransferPath]"},
        {"name": "materialization", "type": "MaterializationProfile"},
        {"name": "layout_metadata", "type": "map[string,string]"}
      ]
    },
    "KeyIdentity": {
