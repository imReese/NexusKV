        {"name": "dtype", "type": "string"},
        {"name": "shape", "type": "list[string]"}
      ]
    },
    "QuantizationMetadata": {
      "fields": [
        {"name": "scheme", "type": "string"},
        {"name": "bits", "type": "int"},
        {"name": "group_size", "type": "int"}
      ]
    },
    "LayoutMetadata": {
      "fields": [
        {"name": "layout", "type": "string"},
        {"name": "page_tokens", "type": "int"},
        {"name": "block_tokens", "type": "int"},
        {"name": "packed", "type": "bool"}
      ]
    },
    "TransferPath": {
      "fields": [
        {"name": "backend", "type": "TransferBackend"},
        {"name": "capabilities", "type": "list[TransferCapability]"}
