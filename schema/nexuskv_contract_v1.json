    "EngineFamily": ["UNKNOWN", "SGLANG", "VLLM"],
    "StateSemanticType": ["MHA_KV", "GQA_KV", "MQA_KV", "MLA_STATE", "GENERIC_CONTAINER"],
    "TensorRole": ["KEY", "VALUE", "LATENT", "POSITION", "AUXILIARY"],
    "Granularity": ["TOKEN", "BLOCK", "PAGE", "SEGMENT"],
    "CompatibilityFlag": [
      "EXACT_REUSE",
      "PREFIX_REUSE",
      "PAGE_REUSE",
      "BLOCK_REUSE",
      "WARM_START",
      "POST_EVICTION_RELOAD"
    ],
    "DeviceClass": ["CPU", "CUDA", "ROCM", "TPU", "OTHER"],
    "BufferKind": ["DEVICE", "HOST_PINNED", "HOST_PAGEABLE", "REMOTE", "FILE_BACKED"],
    "TransferBackend": ["BASELINE_TRANSPORT", "STAGED_COPY", "RDMA", "ZERO_COPY"],
    "TransferCapability": [
