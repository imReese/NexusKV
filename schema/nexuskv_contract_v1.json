        {"name": "descriptor_id", "type": "string"},
        {"name": "engine_family", "type": "EngineFamily"},
        {"name": "semantic_type", "type": "StateSemanticType"},
        {"name": "granularity", "type": "Granularity"},
        {"name": "tensor_specs", "type": "list[TensorSpec]"},
