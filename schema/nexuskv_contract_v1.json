      "fields": [
        {"name": "classification", "type": "MatchClassification"},
        {"name": "matched_key", "type": "ReuseKey"},
        {"name": "requested_key", "type": "QueryKey"},
        {"name": "matched_extent", "type": "MatchExtent"},
        {"name": "entry", "type": "CacheEntry"},
        {"name": "remaining", "type": "RemainingWork"},
        {"name": "compatibility", "type": "CompatibilitySignal"}
      ]
    },
    "ReusableSlice": {
      "fields": [
        {"name": "tokens", "type": "list[int]"},
        {"name": "source_tier", "type": "TierKind"}
      ]
    },
    "PartialHitPlan": {
      "fields": [
        {"name": "disposition", "type": "PlanDisposition"},
        {"name": "reusable", "type": "ReusableSlice"},
        {"name": "remaining", "type": "RemainingWork"},
        {"name": "entry", "type": "CacheEntry"}
      ]
    }
