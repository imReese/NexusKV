# ==============================================================================
# 1. Go (Control-plane & Prototype)
# ==============================================================================
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/

# Test output
*.test
*.out
coverage.txt
coverage.out

# Dependency directories
vendor/

# ==============================================================================
# 2. Rust (Data-plane & nxradixtree core)
# ==============================================================================
# Generated by Cargo
rust/target/
target/

# Backup files generated by rustfmt
**/*.rs.bk

# Crash logs
*.crash

# ==============================================================================
# 3. Python (Engine adapters for SGLang/vLLM)
# ==============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
python/build/
python/dist/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Testing and Coverage
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.pytest_cache/
.hypothesis/

# Jupyter Notebook (如果后续会有压测或探索性的 Notebook)
.ipynb_checkpoints

